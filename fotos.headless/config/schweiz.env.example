# Schweiz-side deployment overrides for fotos.headless/scripts/deploy-schweiz.sh

SCHWEIZ_HOST=schweiz
SCHWEIZ_PORT=7100

# User-space deployment root. The wrapper syncs fotos.headless here, copies the
# bundled vger.headless runtime into runtime/, and starts it with nohup.
SCHWEIZ_REMOTE_DIR=/volume2/homes/gecko/fotos.headless
SCHWEIZ_STORAGE_DIR=/volume2/homes/gecko/fotos-headless-data
SCHWEIZ_NODE=/usr/local/bin/node

# Leave browser UI deployment to fotos.browser unless you explicitly want the
# headless wrapper to embed a local /fotos/ static build as well.
FOTOS_INCLUDE_BROWSER_UI=0

# The mounted Fotos library root that schweiz owns.
SCHWEIZ_FOTOS_DIR=/volume2/homes/gecko/Photos

VGER_WORKSPACE_ROOT=/volume2/homes/gecko/Photos
VGER_SKILLS_PLUGINS_PATH=/volume2/homes/gecko/fotos.headless/skills

VGER_NO_PHONE_BOOK=1
VGER_NO_GLUE_SERVICES=1
TRUST_LOCAL_NETWORK=1
INSTANCE_NAME=fotos-schweiz
VGER_LOCAL_LLAMA_ENABLED=0

# Schweiz should call Spark for semantic embeddings instead of computing them
# locally.
VGER_EMBEDDING_RUNTIME_FAMILY=llama-cpp
LLAMA_CPP_EMBED_URL=http://192.168.178.117:8103
LLAMA_CPP_EMBED_MODEL=gemma-4-e4b-it-vllm
VLLM_EMBED_URL=http://192.168.178.117:8103
VLLM_EMBED_MODEL=gemma-4-e4b-it-vllm
