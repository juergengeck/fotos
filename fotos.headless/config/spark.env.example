# Spark-side deployment overrides for fotos.headless/scripts/deploy-spark.sh

SPARK_HOST=gecko@192.168.178.117
SPARK_HEADLESS_URL=http://192.168.178.117:3000
SPARK_REMOTE_FOTOS_ROOT=/home/gecko/fotos

# Sync the fotos.headless package itself onto the Spark host before replacing
# the running vger-headless container.
SPARK_SYNC_FOTOS_HEADLESS=1

# Start a dedicated vLLM pooling lane for Fotos image embeddings before the
# container replacement. The deploy wrapper calls run-vllm-embed.sh with these.
SPARK_START_EMBED_LANE=1
SPARK_EMBED_MODEL_PRESET=gemma-4-e4b-it
SPARK_EMBED_PORT=8103
SPARK_EMBED_CONTAINER_NAME=spark-vllm-gemma4-e4b-embed

# What the Spark container should mount as /fotos.
FOTOS_PATH=/home/gecko/fotos
VGER_WORKSPACE_ROOT=/fotos/fotos.headless
VGER_SKILLS_PLUGINS_PATH=/fotos/fotos.headless/skills

VGER_NO_PHONE_BOOK=1
VGER_NO_GLUE_SERVICES=1
TRUST_LOCAL_NETWORK=1
VGER_OWNER_EMAIL=glue
VGER_OWNER_PASSWORD=geheim

# Keep the shared text lane plain and feed semantic carrier rows only through
# the sibling alias that advertises image_embeds support.
VLLM_TEXT_URL=http://127.0.0.1:8200
VLLM_TEXT_MODEL=google/gemma-4-E4B-it
VLLM_TEXT_ALIAS=gemma4:e4b
VLLM_TEXT_INTERPRETER_INPUT_TRANSPORT=metadata-only

VGER_SELF_HOSTED_TEXT_LANE_PREFIXES=VLLM_TEXT_SEMANTIC
VLLM_TEXT_SEMANTIC_URL=http://127.0.0.1:8200
VLLM_TEXT_SEMANTIC_MODEL=google/gemma-4-E4B-it
VLLM_TEXT_SEMANTIC_ALIAS=gemma4:e4b:semantic
VLLM_TEXT_SEMANTIC_CAPABILITIES=chat,completion,streaming,structured-output,function-calling,semantic-input-carriers,interpreter-input-carriers,semantic-tokens
VLLM_TEXT_SEMANTIC_INTERPRETER_INPUT_TRANSPORT=vllm-image-embeds-v1
VLLM_TEXT_ENABLE_MM_EMBEDS=1
VLLM_TEXT_MM_EMBEDS_PATCH=gemma4-image-embeds-v1

# The Fotos batch runner uses the dedicated pooling endpoint directly.
VGER_EMBEDDING_RUNTIME_FAMILY=llama-cpp
LLAMA_CPP_EMBED_URL=http://127.0.0.1:8103
LLAMA_CPP_EMBED_MODEL=gemma-4-e4b-it-vllm
VLLM_EMBED_URL=http://127.0.0.1:8103
VLLM_EMBED_MODEL=gemma-4-e4b-it-vllm
