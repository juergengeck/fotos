# pnpm: Enable hoisting for Expo compatibility
# Expo plugins require packages to be hoisted to root node_modules
shamefully-hoist=true
node-linker=hoisted

# Peer dependency handling
auto-install-peers=true
strict-peer-dependencies=false

# This package is intentionally installed from vendored tarballs.
# Workspace linking can accidentally pull sibling repos into node_modules.
link-workspace-packages=false
prefer-workspace-packages=false
